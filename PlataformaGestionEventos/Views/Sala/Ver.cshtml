@model PlataformaGestionEventos.Models.Sala
@{
    ViewData["Title"] = "Detalle de Sala";
}
<style>
    .custom-dashboard {
        font-family: 'Poppins', sans-serif;
        background-color: #21212b;
        color: #b5b5be;
        border-radius: 16px;
        padding: 2.5rem;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
        max-width: 600px;
        margin: 0 auto;
    }
    .custom-title {
        font-weight: 600;
        color: #ffffff;
        font-size: 1.75rem;
    }
    .custom-hr {
        border-top: 1px solid #2d2d3d;
        opacity: 1;
        margin: 1.5rem 0;
    }
    .detail-row {
        background-color: #262633;
        border-radius: 10px;
        padding: 14px 20px;
        margin-bottom: 12px;
    }
    .detail-label {
        color: #7e7e8f;
        font-weight: 500;
        font-size: 0.9rem;
    }
    .detail-value {
        color: #ffffff;
        font-size: 1rem;
        font-weight: 400;
    }
    .btn-custom-edit {
        background: linear-gradient(135deg, #ff527b, #ff715b);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 20px;
        font-weight: 500;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    .btn-custom-edit:hover {
        background: linear-gradient(135deg, #ff715b, #ff527b);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(255, 82, 123, 0.4);
    }
    .btn-custom-back {
        background: transparent;
        border: 1px solid #2d2d3d;
        color: #7e7e8f;
        padding: 12px 30px;
        border-radius: 20px;
        font-weight: 500;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    .btn-custom-back:hover {
        border-color: #5c5c70;
        color: #ffffff;
    }
</style>
<div class="custom-dashboard">
    <h1 class="custom-title m-0 text-center">Detalle de Sala</h1>
    <div class="custom-hr"></div>
    <div class="detail-row d-flex justify-content-between align-items-center">
        <span class="detail-label">Nombre</span>
        <span class="detail-value">@Model.nombre</span>
    </div>
    <div class="detail-row d-flex justify-content-between align-items-center">
        <span class="detail-label">Capacidad</span>
        <span class="detail-value">@Model.capacidad</span>
    </div>
    <div class="detail-row d-flex justify-content-between align-items-center">
        <span class="detail-label">Ubicación</span>
        <span class="detail-value">@Model.ubicacion</span>
    </div>
    <div class="custom-hr"></div>
    <div class="d-flex justify-content-between align-items-center pt-2">
        <a asp-action="Index" class="btn-custom-back">Volver</a>
        <a asp-action="Editar" asp-route-id="@Model.SalaId" class="btn-custom-edit">Editar Sala</a>
    </div>
</div>